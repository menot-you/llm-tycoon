# ============================================================
# Rust server
# ============================================================
server/target/
server/Cargo.lock.bak
**/*.rs.bk

# ============================================================
# Node / Vite (client)
# ============================================================
node_modules/
client/node_modules/
client/dist/
client/.vite/
# client/src/bindings/ IS committed — generated by `cargo test` but
# needed at client build time (Vercel builds client without Rust installed)

# ============================================================
# Python (ml/)
# ============================================================
ml/.venv/
ml/__pycache__/
ml/**/__pycache__/
ml/**/*.pyc
ml/.pytest_cache/
ml/.ruff_cache/
ml/.mypy_cache/
ml/ml_data/
ml/models/

# ============================================================
# Environment & secrets
# ============================================================
.env
.env.local
.env.*.local
!.env.example

# ============================================================
# IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Logs & runtime
# ============================================================
*.log
logs/

# ============================================================
# Docker
# ============================================================
docker-volumes/
